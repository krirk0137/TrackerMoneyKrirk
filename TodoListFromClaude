-- 8.1 Auto-seed on signup (optional). Runs as definer; ignore if a user
--     can already exist before this trigger is created.
create or replace function handle_new_user()
returns trigger
language plpgsql
security definer
set search_path = public
as $$
begin
  perform seed_default_categories(new.id);

  -- give every new user one cash wallet to start with
  insert into accounts (user_id, name, type, icon)
  values (new.id, 'เงินสด', 'cash', '💵');

  return new;
end;
$$;

drop trigger if exists on_auth_user_created on auth.users;
create trigger on_auth_user_created
  after insert on auth.users
  for each row execute function handle_new_user();

